# scripta/hello.fab - Simple hello world script

@ cli "hello"
@ descriptio "Say hello"
@ optio name brevis "n" longum "name" typus textus vel "World" descriptio "Name to greet"
@ optio loud brevis "l" longum "loud" typus bivalens descriptio "Shout the greeting"

incipit argumenta args {
    si args.loud {
        nota scriptum("HELLO, §!", args.name)
    }
    secus {
        nota scriptum("Hello, §.", args.name)
    }
}
