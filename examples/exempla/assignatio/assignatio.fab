# Assignment expressions
# Simple and compound assignment operators

incipit {
    varia numerus x ← 10

    # Simple assignment
    x ← 20
    nota x  # 20

    # Compound assignments
    x ⊕ 5
    nota x  # 25

    x ⊖ 10
    nota x  # 15

    x ⊛ 2
    nota x  # 30

    x ⊘ 3
    nota x  # 10

    # String concatenation
    varia textus s ← "hello"
    s ⊕ " world"
    nota s  # hello world
}
