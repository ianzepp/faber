# si-sin-secus (poetic if-else-if chain)
#
# Poetic alternative to si/sin/secus:
#   si   ← if
#   sin  ← else if ("but if")
#   secus ← else ("otherwise")

incipit {
    fixum hour ← 14

    si hour < 6 {
        nota "Late night"
    }
    sin hour < 12 {
        nota "Morning"
    }
    sin hour < 18 {
        nota "Afternoon"
    }
    sin hour < 22 {
        nota "Evening"
    }
    secus {
        nota "Night"
    }
}
