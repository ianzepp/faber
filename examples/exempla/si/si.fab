# Basic si (if) conditionals
#
# si <condition> { <body> }

incipit {
    fixum x ← 10

    si x > 5 {
        nota "x is greater than 5"
    }

    si x > 20 {
        nota "x is greater than 20"
    }

    # Multiple statements in block
    fixum age ← 25

    si age ≥ 18 {
        nota "Adult"
        nota "Can vote"
    }
}
