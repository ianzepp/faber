# Range containment operator: intra

fixum age ← 25

# Basic intra with ‥ operator (exclusive end)
si age intra 0‥100 {
    nota "age is in valid range"
}

# intra with … (inclusive end)
si age intra 18…65 {
    nota "working age"
}

# intra with ante (explicit exclusive)
si age intra 0 ante 18 {
    nota "minor"
}

incipit {
    nota "intra operator examples"
}
