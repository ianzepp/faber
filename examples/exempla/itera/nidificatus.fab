# Nested itera ex loops

incipit {
    # Nested array iteration
    fixum _ rows ← [1, 2, 3]
    fixum _ cols ← ["A", "B", "C"]

    itera ex rows fixum row {
        itera ex cols fixum col {
            nota row, col
        }
    }

    # Multiplication table
    itera ab 1‥4 fixum i {
        itera ab 1‥4 fixum j {
            nota i, "*", j, "←", i * j
        }
    }

    # Nested ranges
    itera ab 0‥3 fixum x {
        itera ab 0‥3 fixum y {
            nota x, y
        }
    }
}
