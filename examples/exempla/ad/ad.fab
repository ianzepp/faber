# Ad statement - capability calls
# NOTE: In the current Rust path these compile and fail clearly at runtime
# when no provider is linked.

incipit {
    # Basic capability call with sync handler
    ad "fasciculus:lege" ("hello.txt") → textus pro content {
        nota "File contents: §"(content)
    }

    # Async capability call
    @ futura
    ad "caelum:pete" ("https://api.example.com/data") → objectum pro response {
        nota response
    }

    # Multiple arguments
    ad "processus:executa" ("ls", "-la") → textus pro output {
        nota output
    }

    # Complex capability call with error handling
    #ad "rete:connecta" ("127.0.0.1", 8080) → rete.Socket pro socket {
    #    nota "Connected successfully"
    #    socket.claude()
    #} cape err {
    #    nota "Connection failed: §"(err.nuntius)
    #}

    # Capability call without handler (fire-and-forget)
    fixum numerus userId ← 42
    ad "notificatio:mitte" ("User logged in", userId)
}
