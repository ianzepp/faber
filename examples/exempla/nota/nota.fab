# Basic nota diagnostic statements
#
# nota <expr>
# nota <expr>, <expr>, ...

incipit {
    # Simple string output
    nota "Hello, world!"

    # Variable output
    fixum nomen ← "Marcus"
    nota nomen

    # Multiple arguments
    fixum aetas ← 30
    nota "Name:", nomen
    nota "Age:", aetas

    # Expressions
    fixum x ← 10
    fixum y ← 20
    nota "Sum:", x + y

    # Multiple values in one statement
    nota "Coordinates:", x, y
}
