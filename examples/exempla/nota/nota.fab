# Basic nota diagnostic statements
#
# nota <expr>
# nota <expr>, <expr>, ...

incipit {
    # Simple string output
    nota "Hello, world!"

    # Variable output
    fixum _ nomen ← "Marcus"
    nota nomen

    # Multiple arguments
    fixum _ aetas ← 30
    nota "Name:", nomen
    nota "Age:", aetas

    # Expressions
    fixum _ x ← 10
    fixum _ y ← 20
    nota "Sum:", x + y

    # Multiple values in one statement
    nota "Coordinates:", x, y
}
