# Format string expressions using template application

incipit ergo cura arena {
    fixum _ name ← "Marcus"
    fixum _ age ← 30

    # Single placeholder
    fixum _ greeting ← "Salve, §!"(name)
    nota greeting

    # Multiple placeholders
    fixum _ info ← "§ is § years old"(name, age)
    nota info

    # With expression
    fixum _ calc ← "10 + 20 ← §"(10 + 20)
    nota calc
}
