# Format string expressions using scriptum()

incipit ergo cura arena {
    fixum name ← "Marcus"
    fixum age ← 30

    # Single placeholder
    fixum greeting ← scriptum("Salve, §!", name)
    nota greeting

    # Multiple placeholders
    fixum info ← scriptum("§ is § years old", name, age)
    nota info

    # With expression
    fixum calc ← scriptum("10 + 20 ← §", 10 + 20)
    nota calc
}
