# Instantiation expressions with ⇢ (formerly novum)
# Creates new instances of genus types

genus Point {
    numerus x
    numerus y
}

genus Person {
    textus name
    numerus age = 0
}

incipit {
    # Instantiate with all fields
    fixum _ p1 ← Point { x = 10, y = 20 }
    nota p1.x
    nota p1.y

    # With default value
    fixum _ person ← Person { name = "Marcus" }
    nota person.name
    nota person.age
}
