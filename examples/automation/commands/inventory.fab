# Inventory commands for the automation example.

functio sample_record_line() → textus {
    redde "sample-automation  PAUSED  codex  RRULE:FREQ=HOURLY;INTERVAL=1;BYMINUTE=0"
}

functio sample_status() → textus {
    redde "PAUSED"
}

@ imperium "list"
@ descriptio "List automation skill records"
functio list() argumenta args → vacuum {
    nota "root: §"(args.root)
    si args.verbose {
        nota "mode: inventory list"
    }
    nota sample_record_line()
}

@ imperium "show"
@ descriptio "Show one automation record"
@ operandus textus id descriptio "Automation id"
functio show() argumenta args → vacuum {
    nota "id: §"(args.id)
    nota "root: §"(args.root)
    nota "status: §"(sample_status())
    nota "execute: codex"
    nota "model: gpt-5.4-mini"
}

@ imperium "check"
@ descriptio "Validate one automation record"
@ operandus textus id descriptio "Automation id"
functio check() argumenta args → vacuum {
    nota "checking: §"(args.id)
    si args.verbose {
        nota "required fields: id, kind, execute, status, rrule, model, reasoning_effort, cwds"
    }
    nota "ok: fixture metadata shape is valid"
}

probandum "automation inventory" tag "automation" {
    proba "sample record line names the paused fixture" {
        adfirma sample_record_line() ≡ "sample-automation  PAUSED  codex  RRULE:FREQ=HOURLY;INTERVAL=1;BYMINUTE=0"
    }

    proba "sample status is paused" {
        adfirma sample_status() ≡ "PAUSED"
    }
}
