#!/usr/bin/env bash
# Type-check the maintained TypeScript bootstrap compiler surface.
#
# The family repo intentionally contains older and generated TypeScript trees
# that are not active blocking gates. Keep this check aligned with the repo
# contract and the dedicated tsconfig for nanus-ts.

set -euo pipefail

cd "$(dirname "$0")/.."

tsc --noEmit -p tsconfig.nanus.json
