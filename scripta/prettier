#!/usr/bin/env bash
# Format source code with Prettier
#
# Formats known Prettier-supported project files.
# Use --check flag to validate formatting without making changes.
#
# Usage:
#   ./scripta/prettier          # Format all files in-place
#   ./scripta/prettier --check  # Check formatting (CI mode)
#
# Covers:
#   - docs/grammatica/**/*.md
# Unknown Faber files are included for future parser/plugin support, but skipped today.

set -euo pipefail

cd "$(dirname "$0")/.."

if [[ "${1:-}" == "--check" ]]; then
    prettier --ignore-unknown --check "radix/stdlib/**/*.fab" "examples/**/*.fab" "docs/grammatica/**/*.md"
else
    prettier --ignore-unknown --write "radix/stdlib/**/*.fab" "examples/**/*.fab" "docs/grammatica/**/*.md"
fi
