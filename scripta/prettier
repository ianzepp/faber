#!/usr/bin/env bash
# Format source code with Prettier
#
# Formats TypeScript source files and YAML test specifications.
# Use --check flag to validate formatting without making changes.
#
# Usage:
#   ./scripta/prettier          # Format all files in-place
#   ./scripta/prettier --check  # Check formatting (CI mode)
#
# Covers:
#   - compilers/**/*.ts, runtimes/**/*.ts, tests/**/*.ts (TypeScript source files)
#   - tests/proba/**/*.yaml (test specifications)

set -euo pipefail

cd "$(dirname "$0")/.."

if [[ "${1:-}" == "--check" ]]; then
    prettier --check "compilers/**/*.ts" "runtimes/**/*.ts" "tests/**/*.ts" "compilers/**/*.fab" "stdlib/**/*.fab" "tests/proba/**/*.yaml" "examples/**/*.fab" "docs/grammatica/**/*.md"
else
    prettier --write "compilers/**/*.ts" "runtimes/**/*.ts" "tests/**/*.ts" "compilers/**/*.fab" "stdlib/**/*.fab" "tests/proba/**/*.yaml" "examples/**/*.fab" "docs/grammatica/**/*.md"
fi
