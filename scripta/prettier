#!/usr/bin/env bash
# Format source code with Prettier
#
# Formats current Faber source and Markdown documentation.
# Use --check flag to validate formatting without making changes.
#
# Usage:
#   ./scripta/prettier          # Format all files in-place
#   ./scripta/prettier --check  # Check formatting (CI mode)
#
# Covers:
#   - radix/stdlib/**/*.fab
#   - examples/**/*.fab
#   - docs/grammatica/**/*.md

set -euo pipefail

cd "$(dirname "$0")/.."

if [[ "${1:-}" == "--check" ]]; then
    prettier --check "radix/stdlib/**/*.fab" "examples/**/*.fab" "docs/grammatica/**/*.md"
else
    prettier --write "radix/stdlib/**/*.fab" "examples/**/*.fab" "docs/grammatica/**/*.md"
fi
