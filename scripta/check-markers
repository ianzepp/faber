#!/usr/bin/env bash
# Guardrail for sponte/fixus/∪ declaration marker migration.
# Rejects reintroduction of legacy `si` nullable/optional syntax, `T?` suffix types,
# reversed marker order, and the historical `datus` keyword on live surfaces.
#
# Run manually: ./scripta/check-markers
# Invoked by ./scripta/ci as part of the full validation gate.
#
# Allowlist rationale:
# - Control-flow `si` (the conditional) is intentionally still present.
# - Optional chaining `?.` `?[]` `?()` and their explain docs.
# - EBNF grammar notation using `?` for "optional".
# - Negative test sources that embed the legacy spellings to prove rejection.
# - Historical migration records under docs/factory/sponte-fixus-declaration-markers/.
# - AGENTS.md explicitly banning `Type?` (the ban line itself must not trigger).

set -euo pipefail

cd "$(dirname "$0")/.."

# Live surfaces only (no target/, no deep factory history for the migration itself)
surfaces=(
  AGENTS.md
  EBNF.md
  explain
  examples
  stdlib
  crates
)

# globs to exclude noisy or allowed locations
exclude_globs=(
  '!target/**'
  '!docs/factory/sponte-fixus-declaration-markers/**'
  '!**/*test*.rs'
  '!crates/radix/tests/**'
  '!**/*_test.rs'
  '!explain/question-*.md'
  '!explain/coverage.toml'   # may contain unrelated
)

rg_opts=(--no-heading --line-number --color=never)
for glob in "${exclude_globs[@]}"; do
  rg_opts+=(--glob "$glob")
done

# Bad patterns for legacy si-as-nullable (anchored to declaration / type positions)
si_bad='→\s*si\b|\b(fixum|varia)\s+si\s+\w+|\btypus\s+\w+\s*=\s*si\s+\w+|\bsi\s+(textus|numerus|fractus|bivalens|vacuum|valor|quidlibet|octeti|series|[A-Z][A-Za-z0-9_]*)\s+\w+'

# Bad T? as type (not chaining, not EBNF).
# Keep this to known built-in type spellings; a generic capitalized-word regex catches prose
# headings such as "Why Both Forms?".
question_bad='\b(textus|numerus|fractus|bivalens|vacuum|valor|quidlibet|octeti|series)\?'

# Historical keyword that must not reappear as current syntax
datus_bad='\bdatus\b'

violations=""

check_pattern() {
  local pattern="$1"
  local desc="$2"
  local hits
  hits=$(rg "${rg_opts[@]}" "$pattern" "${surfaces[@]}" 2>/dev/null || true)

  # Additional allowlist filtering for common false positives that rg glob did not catch.
  # Do not filter `si <builtin-type> <name>` here: that is exactly the legacy form this
  # guardrail exists to catch. Control-flow `si` remains allowed because it does not match
  # the typed declaration patterns above.
  hits=$(echo "$hits" | grep -E -v \
    '^\s*$|Type\?|IDENTIFIER\?|No invented|:=.*\?|optional chaining|question-(dot|bracket|paren)|EBNF|grammar' \
    || true)

  if [ -n "$hits" ]; then
    violations="${violations}${desc}:\n${hits}\n\n"
  fi
}

check_pattern "$si_bad" "Legacy si-as-optional/nullable"
check_pattern "$question_bad" "Legacy T? nullable type suffix"
check_pattern "$datus_bad" "Historical datus keyword"

if [ -n "$violations" ]; then
  echo "❌ Declaration marker guardrail FAILED"
  echo -e "$violations"
  echo "See docs/factory/sponte-fixus-declaration-markers/phase-7-delivery.md for allowed exceptions and rationale."
  exit 1
fi

echo "✅ Declaration marker guardrail clean (sponte/fixus/∪ shape protected)"
exit 0
