#!/usr/bin/env bash
# Install the current faber binary as ~/.local/bin/faber.
set -euo pipefail

cd "$(dirname "$0")/.."

if [[ ! -f radix/target/release/faber ]]; then
    echo "Error: radix/target/release/faber not found. Run 'bun run build:radix' first."
    exit 1
fi

mkdir -p ~/.local/bin
rm -f ~/.local/bin/faber
ln -s "$(pwd)/radix/target/release/faber" ~/.local/bin/faber
echo "Installed: ~/.local/bin/faber -> $(pwd)/radix/target/release/faber"
