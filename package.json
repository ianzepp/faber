{
    "name": "faber",
    "version": "0.7.0",
    "description": "A Latin-to-JavaScript transpiler - The Roman Craftsman",
    "module": "index.ts",
    "type": "module",
    "scripts": {
        "ci": "bun run ci:radix-rs",
        "ci:radix-rs": "bun run check:radix-rs && bun run test:radix-rs",
        "check:radix-rs": "cargo fmt --manifest-path compilers/radix-rs/Cargo.toml --all -- --check",
        "test:radix-rs": "cargo test --manifest-path compilers/radix-rs/Cargo.toml",
        "build": "bun ./scripta/build.ts",
        "build:bootstrap": "bun ./scripta/build-bootstrap.ts",
        "build:nanus-ts": "bun ./scripta/build-nanus-ts.ts",
        "build:nanus-go": "bun ./scripta/build-nanus-go.ts",
        "build:nanus-rs": "bun ./scripta/build-nanus-rs.ts",
        "build:nanus-py": "bun ./scripta/build-nanus-py.ts",
        "build:radix-rs": "cargo build --release --manifest-path compilers/radix-rs/Cargo.toml && mkdir -p opus/bin && cp compilers/radix-rs/target/release/radix opus/bin/radix-rs",
        "build:exempla": "bun ./scripta/build-exempla.ts",
        "build:exempla:radix-rs": "bun run build:radix-rs && bun ./scripta/build-exempla.ts -c radix-rs",
        "build:exempla:radix-go": "bun run build:radix-rs && bun ./scripta/build-exempla.ts -c radix-rs -t go",
        "build:golden": "bun ./scripta/build-golden.ts",
        "test:nanus-ts": "./scripta/test",
        "test:legacy": "bun run test:nanus-ts",
        "test": "./scripta/test",
        "test:report": "./scripta/test-report",
        "golden": "bun ./scripta/golden.ts",
        "lint:nanus-ts": "./scripta/lint",
        "lint": "./scripta/lint",
        "lint:fix": "./scripta/lint --fix",
        "typecheck:legacy": "./scripta/typecheck",
        "prettier": "./scripta/prettier",
        "prettier:check": "./scripta/prettier --check",
        "typecheck": "./scripta/typecheck",
        "glyph": "bun ./scripta/build-glyph.ts",
        "verify:exempla": "bun ./scripta/verify-exempla.ts",
        "verify:nanus": "bun ./scripta/verify-nanus.ts",
        "use": "./scripta/use",
        "release": "./scripta/release"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/bun": "latest",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.7.4",
        "typescript-eslint": "^8.50.0"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "keywords": [
        "latin",
        "transpiler",
        "compiler",
        "javascript"
    ],
    "license": "MIT",
    "dependencies": {
        "smol-toml": "^1.6.0",
        "yaml": "^2.8.2"
    }
}
