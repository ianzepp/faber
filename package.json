{
    "name": "faber",
    "version": "0.7.0",
    "description": "A Latin programming language compiler - The Roman Craftsman",
    "module": "index.ts",
    "type": "module",
    "scripts": {
        "ci": "bun run check:radix && bun run test:radix",
        "check:radix": "cargo fmt --manifest-path radix/Cargo.toml --all -- --check",
        "test:radix": "cargo test --manifest-path radix/Cargo.toml",
        "build:radix": "cargo build --release --manifest-path radix/Cargo.toml -p radix",
        "build": "bun run build:radix",
        "test": "bun run test:radix",
        "lint": "cargo clippy --manifest-path radix/Cargo.toml --all-targets --all-features -- -D warnings",
        "prettier": "./scripta/prettier",
        "prettier:check": "./scripta/prettier --check"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/bun": "latest",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.7.4",
        "typescript-eslint": "^8.50.0"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "keywords": [
        "latin",
        "compiler",
        "language"
    ],
    "license": "MIT",
    "dependencies": {
        "smol-toml": "^1.6.0",
        "yaml": "^2.8.2"
    }
}
